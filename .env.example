AIPERMISSION_BACKEND_PORT=8080
AIPERMISSION_FRONTEND_PORT=3210
# Empty values make the Docker UI use same-origin /api and MCP setup use the UI origin.
AIPERMISSION_API_URL=
AIPERMISSION_MCP_API_URL=
# Optional. Omit for auto-generation; if set explicitly, use at least 32 characters.
# AIPERMISSION_GATEWAY_SECRET=replace-with-at-least-32-random-characters
# Optional. Defaults to the configured frontend port only.
# AIPERMISSION_ALLOWED_ORIGINS=http://localhost:3210,http://127.0.0.1:3210
